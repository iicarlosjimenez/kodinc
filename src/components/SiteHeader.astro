---
const nav = [
	{ href: '#problema', label: 'El problema' },
	{ href: '#solucion', label: 'Cómo ayudamos' },
	{ href: '#beneficios', label: 'Beneficios' },
	{ href: '#casos', label: 'Sectores' },
	{ href: '#gobierno', label: 'Identidad digital' },
	{ href: '#contacto', label: 'Contacto' },
];
---

<header
	class="sticky top-0 z-50 border-b border-white/[0.08] bg-[#0c0d12]/85 backdrop-blur-md"
	role="banner"
>
	<div
		class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-3 md:flex-nowrap"
	>
		<a href="/" class="flex flex-col leading-tight no-underline text-inherit" aria-label="kodinc — inicio">
			<span class="text-lg font-extrabold tracking-tight text-text">kodinc</span>
			<span class="text-[0.7rem] text-muted">Tecnología que conecta</span>
		</a>
		<nav class="order-3 w-full md:order-none md:w-auto" aria-label="Secciones principales">
			<ul class="m-0 flex list-none flex-wrap justify-center gap-x-4 gap-y-1 p-0 md:justify-end">
				{
					nav.map(({ href, label }) => (
						<li>
							<a
								href={href}
								class="text-sm font-medium text-muted no-underline hover:text-text hover:underline focus-visible:text-text focus-visible:underline"
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<a
			class="inline-flex shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[#b4ffa8] to-accent-muted px-4 py-2 text-sm font-bold text-[#0c0d12] no-underline transition duration-150 hover:scale-[1.03] hover:brightness-105 active:scale-[0.99] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
			href="#contacto"
		>
			Agenda una demo
		</a>
	</div>
</header>
