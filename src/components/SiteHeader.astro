---
const nav = [
	{ href: '#problema', label: 'El problema' },
	{ href: '#solucion', label: 'Cómo ayudamos' },
	{ href: '#beneficios', label: 'Beneficios' },
	{ href: '#casos', label: 'Sectores' },
	{ href: '#gobierno', label: 'Identidad digital' },
	{ href: '#contacto', label: 'Contacto' },
];
---

<header class="site-header" role="banner">
	<div class="inner">
		<a href="/" class="brand" aria-label="kodinc — inicio">
			<span class="brand-name">kodinc</span>
			<span class="brand-tag">Tecnología que conecta</span>
		</a>
		<nav class="nav" aria-label="Secciones principales">
			<ul>
				{
					nav.map(({ href, label }) => (
						<li>
							<a href={href}>{label}</a>
						</li>
					))
				}
			</ul>
		</nav>
		<a class="cta-header" href="#contacto">Agenda una demo</a>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(12, 13, 18, 0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}
	.inner {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0.75rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.brand {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		line-height: 1.2;
	}
	.brand-name {
		font-weight: 800;
		font-size: 1.125rem;
		letter-spacing: -0.02em;
	}
	.brand-tag {
		font-size: 0.7rem;
		color: var(--text-muted);
	}
	.nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1rem;
	}
	.nav a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.875rem;
		font-weight: 500;
	}
	.nav a:hover,
	.nav a:focus-visible {
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.cta-header {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 700;
		text-decoration: none;
		color: #0c0d12;
		background: linear-gradient(120deg, rgb(180, 255, 200), rgb(var(--accent-muted)));
		white-space: nowrap;
	}
	.cta-header:hover,
	.cta-header:focus-visible {
		filter: brightness(1.05);
	}
	.cta-header:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 2px;
	}
	@media (max-width: 900px) {
		.nav {
			order: 3;
			width: 100%;
			justify-content: center;
		}
	}
</style>
