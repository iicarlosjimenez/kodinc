---
import Reveal from './motion/Reveal.tsx';

interface Props {
	id?: string;
	title: string;
	eyebrow?: string;
	class?: string;
}

const { id, title, eyebrow, class: className } = Astro.props;
const headingId = id ? `${id}-titulo` : undefined;
---

<section
	id={id}
	class:list={['border-t border-white/[0.08] px-5 py-16 md:py-20', className]}
	aria-labelledby={headingId}
>
	<div class="mx-auto max-w-6xl">
		{
			eyebrow && (
				<p class="mb-2 text-xs font-bold uppercase tracking-[0.12em] text-accent-muted">
					{eyebrow}
				</p>
			)
		}
		<h2
			id={headingId}
			class="mb-8 max-w-4xl text-balance text-2xl font-extrabold tracking-tight text-text md:text-3xl md:leading-tight"
		>
			{title}
		</h2>
		<Reveal client:visible>
			<slot />
		</Reveal>
	</div>
</section>
