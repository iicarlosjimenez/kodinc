---
interface Props {
	href: string;
	variant?: 'primary' | 'secondary';
	label: string;
}

const { href, variant = 'primary', label } = Astro.props;

const base =
	'inline-flex min-h-[3rem] shrink-0 items-center justify-center rounded-full px-6 py-3.5 text-center text-base font-bold no-underline transition duration-150 ease-out hover:scale-[1.03] active:scale-[0.99] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-accent-muted';

const variants = {
	primary:
		'bg-gradient-to-br from-[#7c5cff] via-[#7c5cff] to-[#38bdf8] text-[#0c0d12] shadow-lg shadow-black/20 hover:brightness-105',
	secondary:
		'border-2 border-white/10 bg-transparent text-text hover:border-white/25 hover:bg-white/[0.03]',
};
---

<a class:list={[base, variants[variant]]} href={href}>
	{label}
</a>
